# PlayDrama Studio local/dev environment

# API server port.
PORT=8787

# API server host.
HOST=127.0.0.1

# Storage driver.
# Current runnable driver: json
# Planned production driver: postgres
PLAYDRAMA_STORAGE_DRIVER=json

# Local JSON database path for the json driver.
PLAYDRAMA_DB_PATH=server/data/playdrama-db.json

# Future PostgreSQL/Supabase connection string.
# Example:
# PLAYDRAMA_DATABASE_URL=postgresql://postgres:password@localhost:5432/playdrama
# DATABASE_URL=postgresql://postgres:password@localhost:5432/playdrama
PLAYDRAMA_DATABASE_URL=
DATABASE_URL=

# Netlify Database mode.
# On Netlify, install @netlify/database, deploy migrations, and set this true
# instead of writing a database URL into the codebase.
NETLIFY_DATABASE_READY=false

# Future auth/session secrets.
AUTH_PROVIDER=local-demo
PLAYDRAMA_DEMO_USER_ID=usr_001
AUTH_SESSION_SECRET=change-me-before-production
AUTH_PROVIDER_ADAPTER_READY=false

# Built-in production auth option. Uses email verification codes plus
# PostgreSQL-backed bearer sessions.
AUTH_EMAIL_CODE_READY=false
AUTH_EMAIL_CODE_TTL_MINUTES=10
AUTH_SESSION_TTL_DAYS=30
AUTH_EMAIL_CODE_DEV_REVEAL=false

# Built-in phone auth option. Uses SMS verification codes plus
# PostgreSQL-backed bearer sessions.
AUTH_SMS_CODE_READY=false
AUTH_SMS_CODE_TTL_MINUTES=10
AUTH_SMS_CODE_DEV_REVEAL=false

# Netlify Identity. Use this on the Netlify preview/production site.
NETLIFY_IDENTITY_READY=false

# Trusted identity gateway. Use this when an upstream login service or gateway
# verifies the user and forwards x-playdrama-identity-* headers to the API.
AUTH_TRUSTED_IDENTITY_READY=false
AUTH_TRUSTED_IDENTITY_SECRET=

# Supabase Auth.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Auth.js / OAuth.
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# WeChat login.
WECHAT_LOGIN_APP_ID=
WECHAT_LOGIN_APP_SECRET=

# Mini-program channel launch.
MINI_PROGRAM_WEBVIEW_DOMAIN_READY=false
DOUYIN_CLIENT_KEY=
DOUYIN_CLIENT_SECRET=
DOUYIN_ACCESS_TOKEN=
DOUYIN_OPEN_ID=
DOUYIN_MINI_APP_ID=
DOUYIN_MINI_APP_SECRET=
DOUYIN_MINI_PAY_READY=false
WECHAT_MINI_APP_ID=
WECHAT_MINI_APP_SECRET=
WECHAT_MINI_ORIGINAL_ID=
WECHAT_MINI_PAY_READY=false

# AI model provider for commercial China mainland release.
# Options planned by the product strategy: stub, deepseek, qwen, doubao, zhipu
AI_PROVIDER=stub
AI_MODEL_NAME=
AI_PROVIDER_ADAPTER_READY=false
AI_COST_TRACKING_READY=false
AI_REQUEST_TIMEOUT_MS=120000
AI_PRICE_CURRENCY=USD
AI_INPUT_PRICE_PER_MILLION=0.115
AI_OUTPUT_PRICE_PER_MILLION=0.287
DEEPSEEK_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DOUBAO_API_KEY=
ZHIPU_API_KEY=

# Short drama video generation provider.
# Keep VIDEO_PROVIDER=stub until you have a valid provider key and balance.
VIDEO_PROVIDER=stub
VIDEO_MODEL_NAME=
VIDEO_REQUEST_TIMEOUT_MS=60000
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_VIDEO_MODEL=wan2.7-t2v-2026-04-25
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io
MINIMAX_VIDEO_MODEL=video-01
VIDU_API_KEY=
VIDU_BASE_URL=https://api.vidu.com
VIDU_VIDEO_MODEL=vidu2.0
RUNWAY_API_KEY=
RUNWAY_BASE_URL=https://api.dev.runwayml.com
RUNWAY_VIDEO_MODEL=gen4.5

# Volcengine (火山引擎) Seedance 2.0 video generation via Ark platform.
# Use your Ark API Key from https://console.volcengine.com/ark
VOLCANO_ARK_API_KEY=
VOLCANO_ACCESS_KEY_ID=
VOLCANO_SEEDANCE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3
VOLCANO_SEEDANCE_MODEL=doubao-seedance-2-0-260128
VOLCANO_SEEDANCE_TIMEOUT_MS=120000

CONTENT_SAFETY_PROVIDER=local-rules
CONTENT_SAFETY_POLICY_READY=false
CONTENT_SAFETY_POLICY_VERSION=local-rules-v1
CONTENT_SAFETY_API_KEY=

EMAIL_PROVIDER=log
EMAIL_WEBHOOK_URL=
PLAYDRAMA_LEAD_NOTIFY_EMAIL=
EMAIL_DEV_WEBHOOK_BASE=http://127.0.0.1:8790
EMAIL_API_KEY=
EMAIL_CALLBACK_SECRET=
# bearer or hmac-sha256
EMAIL_CALLBACK_SIGNATURE_MODE=bearer
EMAIL_DEV_WEBHOOK_PORT=8790
EMAIL_DEV_FORCE_STATUS=queued

# Aliyun DirectMail production adapter.
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_DM_ENDPOINT=https://dm.aliyuncs.com
ALIYUN_DM_REGION=cn-hangzhou
ALIYUN_DM_ACCOUNT_NAME=
ALIYUN_DM_FROM_ALIAS=PlayDrama Studio
ALIYUN_DM_TAG_NAME=
ALIYUN_DM_ADDRESS_TYPE=1
ALIYUN_DM_REPLY_TO_ADDRESS=true
ALIYUN_DM_DRY_RUN=true
ALIYUN_DM_LIVE_TEST_EMAIL=

# Tencent Cloud SES production adapter.
TENCENTCLOUD_SECRET_ID=
TENCENTCLOUD_SECRET_KEY=
TENCENTCLOUD_SESSION_TOKEN=
TENCENT_SES_ENDPOINT=ses.tencentcloudapi.com
TENCENT_SES_REGION=ap-guangzhou
TENCENT_SES_FROM_EMAIL=
TENCENT_SES_REPLY_TO=
TENCENT_SES_TEMPLATE_ID=
TENCENT_SES_DRY_RUN=false
TENCENT_SES_LIVE_TEST_EMAIL=

# Tencent Cloud SMS auth-code adapter.
# Official SendSms API requires E.164 phone numbers, e.g. +8613812345678.
SMS_PROVIDER=log
TENCENT_SMS_ENDPOINT=sms.tencentcloudapi.com
TENCENT_SMS_REGION=ap-guangzhou
TENCENT_SMS_VERSION=2021-01-11
TENCENT_SMS_SDK_APP_ID=
TENCENT_SMS_SIGN_NAME=
TENCENT_SMS_TEMPLATE_ID=
# Comma-separated template variables. Default supports templates like:
# "Your verification code is {1}, valid for {2} minutes."
TENCENT_SMS_TEMPLATE_PARAMS=code,ttlMinutes
TENCENT_SMS_EXTEND_CODE=
TENCENT_SMS_SENDER_ID=
TENCENT_SMS_DRY_RUN=true
TENCENT_SMS_REQUEST_TIMEOUT_MS=8000
TENCENT_SMS_LIVE_TEST_PHONE=

# Payment provider.
# Options: disabled, sandbox, wechat, alipay, stripe
PAYMENT_PROVIDER=disabled
PAYMENT_CURRENCY=CNY
PAYMENT_SANDBOX_READY=false
PAYMENT_SANDBOX_VERIFIED=false
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PATH=
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_SELLER_ID=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

INVITE_EXPIRES_DAYS=7
APP_BASE_URL=http://127.0.0.1:5177

# Frontend build-time API base.
# Use HTTPS production API URL when deploying the frontend.
VITE_PLAYDRAMA_API_BASE=http://127.0.0.1:8787
# Optional comma-separated fallback list.
VITE_PLAYDRAMA_API_BASES=
