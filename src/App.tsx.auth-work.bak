                        : emailProvider.tencentSes?.configured
                          ? ' 鍑瘉宸查厤缃?'
                          : ' 绛夊緟鍑瘉'}
                    </strong>
                    {(emailProvider.tencentSes?.missing || []).slice(0, 3).map((item) => (
                      <div className="readiness-row" key={item.id}>
                        <span>{item.label}</span>
                        <em>{item.action}</em>
                      </div>
                    ))}
                  </div>
                )}
                {emailProvider?.provider === 'aliyun-directmail' && (
                  <div className="readiness-list">
                    <strong>
                      闃块噷浜戦偖浠舵帹閫?路 {emailProvider.aliyunDirectMail?.region || 'cn-hangzhou'} 路
                      {emailProvider.aliyunDirectMail?.dryRun
                        ? ' 骞茶窇婕旂粌'
                        : emailProvider.aliyunDirectMail?.configured
                          ? ' 鍑瘉宸查厤缃?'
                          : ' 绛夊緟鍑瘉'}
                    </strong>
                    {(emailProvider.aliyunDirectMail?.missing || []).slice(0, 3).map((item) => (
                      <div className="readiness-row" key={item.id}>
                        <span>{item.label}</span>
                        <em>{item.action}</em>
                      </div>
                    ))}
                  </div>
                )}
                {inviteDeliveries.length === 0 ? (
                  <p className="delivery-empty">褰撳墠宸ヤ綔鍖鸿繕娌℃湁閭€璇烽偖浠惰褰?</p>
                ) : (
                  inviteDeliveries.slice(0, 4).map((delivery) => (
                    <div className="delivery-row" key={delivery.id}>
                      <div>
                        <span>{delivery.to}</span>
                        <em>
                          {delivery.provider} 路 {delivery.status} 路 {delivery.role}
                          {delivery.errorMessage ? ` 路 ${delivery.errorMessage}` : ''}
                        </em>
                      </div>
                      <div className="delivery-actions">
                        <button
                          className="ghost-button compact"
                          type="button"
                          onClick={() => markDeliveryStatus(delivery.id, 'sent')}
                        >
                          sent
                        </button>
                        <button
                          className="ghost-button compact danger"
                          type="button"
                          onClick={() => markDeliveryStatus(delivery.id, 'failed')}
                        >
                          failed
                        </button>
                      </div>
                    </div>
                  ))
                )}
                <div className="provider-recommendations">
                  <strong>姝ｅ紡鏈嶅姟鍟嗘帹鑽?</strong>
                  {(emailProvider?.recommendations || []).slice(0, 4).map((provider) => (
                    <div className="provider-row" key={provider.id}>
                      <span>{provider.priority}. {provider.displayName}</span>
                      <em>
                        {provider.market} 路 {provider.fit} 路 {provider.callbackMode}
                      </em>
                    </div>
                  ))}
                </div>
              </div>
            </section>

            <section className="panel editor-panel">
              <div className="panel-header">
                <div>
                  <p className="eyebrow">Audit</p>
                  <h2>椤圭洰娲诲姩</h2>
                </div>
              </div>
              <div className="audit-filter">
                <label>
                  <span>褰撳墠浣滃搧</span>
                  <strong>{project.title}</strong>
                </label>
                <label>
                  <span>鍔ㄤ綔绛涢€?</span>
                  <select
                    value={auditActionFilter}
                    onChange={(event) => setAuditActionFilter(event.target.value)}
                  >
                    {auditActionOptions.map((option) => (
                      <option key={option.value} value={option.value}>
                        {option.label}
                      </option>
                    ))}
                  </select>
                </label>
              </div>
              <div className="audit-list activity-list">
                {projectTimelineEntries.length === 0 && (
                  <span>褰撳墠浣滃搧鏆傛棤鍖归厤娲诲姩</span>
                )}
                {projectTimelineEntries.map((entry) => (
                  <article className="audit-row" key={entry.id}>
                    <strong>{entry.action}</strong>
                    <span>
                      {entry.targetType} 路 {entry.targetId}
                    </span>
                    <em>{new Date(entry.createdAt).toLocaleString()}</em>
                  </article>
                ))}
              </div>
            </section>

            <section className="panel editor-panel">
              <div className="panel-header">
                <div>
                  <p className="eyebrow">Workspace Audit</p>
                  <h2>鏈€杩戞搷浣?</h2>
                </div>
              </div>
              <div className="audit-list">
                {recentAuditEntries.length === 0 && <span>鏆傛棤鍚庣鎿嶄綔璁板綍</span>}
                {recentAuditEntries.map((entry) => (
                  <article className="audit-row" key={entry.id}>
                    <strong>{entry.action}</strong>
                    <span>{entry.targetType} 路 {entry.targetId}</span>
                  </article>
                ))}
              </div>
            </section>

            <section className="panel editor-panel">
              <div className="panel-header">
                <div>
                  <p className="eyebrow">Demo Gallery</p>
                  <h2>鏍风墖搴撴ā鍨?</h2>
                </div>
              </div>
              <div className="gallery-list">
                {galleryItems.map((item) => (
                  <article className="gallery-item" key={item.id}>
                    <strong>{item.title}</strong>
                    <span>{item.category}</span>
                    <em>{item.status} 路 {item.completion}</em>
                  </article>
                ))}
              </div>
            </section>

            <section className="panel editor-panel">
              <div className="panel-header">
                <div>
                  <p className="eyebrow">Variables</p>
                  <h2>鍙橀噺鏉′欢</h2>
                </div>
                <button className="icon-button" type="button" onClick={addVariable} aria-label="Add variable">
                  <Plus size={16} />
                </button>
              </div>
              <div className="variable-list">
                {project.variables.map((variable, index) => (
                  <article className="variable-row" key={`${variable.id}-${index}`}>
                    <input
                      value={variable.label}
                      onChange={(event) => updateVariable(index, 'label', event.target.value)}
                    />
                    <select
                      value={variable.type}
                      onChange={(event) => updateVariable(index, 'type', event.target.value)}
                    >
                      {variableTypes.map((type) => (
                        <option key={type}>{type}</option>
                      ))}
                    </select>
                    <input
                      value={variable.defaultValue}
                      onChange={(event) =>
                        updateVariable(index, 'defaultValue', event.target.value)
                      }
                    />
                    <button
                      className="icon-button danger small"
                      type="button"
                      aria-label="Remove variable"
                      onClick={() => removeVariable(index)}
                    >
                      <Trash2 size={14} />
                    </button>
                  </article>
                ))}
              </div>
            </section>

            <section className="panel editor-panel">
              <div className="panel-header">
                <div>
                  <p className="eyebrow">Node Editor</p>
                  <h2>鑺傜偣缂栬緫</h2>
                </div>
                <button
                  className="icon-button danger"
                  type="button"
                  aria-label="Delete node"
                  onClick={() => removeStoryNode(selectedNode.id)}
                  disabled={storyNodes.length === 1}
                >
                  <Trash2 size={16} />
                </button>
              </div>

              <div className="form-grid">
                <label>
                  <span>鏍囬</span>
                  <input
                    value={selectedNode.title}
                    onChange={(event) => updateSelectedNode('title', event.target.value)}
                  />
                </label>
                <label>
                  <span>绫诲瀷</span>
                  <select
                    value={selectedNode.kind}
                    onChange={(event) =>
                      updateSelectedNode('kind', event.target.value as NodeKind)
                    }
                  >
                    {nodeKinds.map((kind) => (
                      <option key={kind}>{kind}</option>
                    ))}
                  </select>
                </label>
                <label>
                  <span>鎸囨爣</span>
                  <input
                    value={selectedNode.metric}
                    onChange={(event) => updateSelectedNode('metric', event.target.value)}
                  />
                </label>
                <label className="wide-field">
                  <span>鍓ф儏鎽樿</span>
                  <textarea
                    value={selectedNode.summary}
                    onChange={(event) =>
                      updateSelectedNode('summary', event.target.value)
                    }
                  />
                </label>
              </div>

              <div className="choice-editor">
                <div className="section-title light">
                  <span>鐜╁閫夋嫨鍜屽垎鏀?</span>
                  <button
                    className="icon-button"
                    type="button"
                    onClick={addChoice}
                    aria-label="Add choice"
                  >
                    <Plus size={16} />
                  </button>
                </div>
                {selectedNode.choices.map((item, index) => (
                  <article className="branch-row" key={item.id}>
                    <label>
                      <span>閫夋嫨鏂囨</span>
                      <input
                        value={item.label}
                        onChange={(event) =>
                          updateChoice(index, 'label', event.target.value)
                        }
                      />
                    </label>
                    <label>
                      <span>鐩爣鑺傜偣</span>
                      <select
                        value={item.targetNodeId}
                        onChange={(event) =>
                          updateChoice(index, 'targetNodeId', event.target.value)
                        }
                      >
                        {storyNodes.map((node) => (
                          <option key={node.id} value={node.id}>
                            {node.id} 路 {node.title}
                          </option>
                        ))}
                      </select>
                    </label>
                    <label className="wide-field">
                      <span>瑙﹀彂鏉′欢</span>
                      <input
                        value={item.condition}
                        placeholder="渚嬪锛氱嚎绱?>= 3"
                        onChange={(event) =>
                          updateChoice(index, 'condition', event.target.value)
                        }
                      />
                    </label>
                    <button
                      className="icon-button danger small branch-delete"
                      type="button"
                      aria-label="Remove choice"
                      onClick={() => removeChoice(index)}
                    >
                      <Trash2 size={14} />
                    </button>
                  </article>
                ))}
              </div>
            </section>

            {player}

            <section className="panel">
              <div className="panel-header">
                <div>
                  <p className="eyebrow">Characters</p>
                  <h2>瑙掕壊涓€鑷存€?</h2>
                </div>
                <button className="icon-button" type="button" onClick={addCharacter} aria-label="Add character">
                  <Plus size={16} />
                </button>
              </div>
              <div className="character-list editable">
                {project.characters.map((character, index) => (
                  <article className="character-card" key={`${character.name}-${index}`}>
                    <div className="character-card-header">
                      <span
                        className="avatar-dot"
                        style={{ background: character.color }}
                      />
                      <button
                        className="icon-button danger small"
                        type="button"
                        aria-label="Remove character"
                        onClick={() => removeCharacter(index)}
                      >
                        <Trash2 size={14} />
                      </button>
                    </div>
                    <label>
                      <span>濮撳悕</span>
                      <input
                        value={character.name}
                        onChange={(event) =>
                          updateCharacter(index, 'name', event.target.value)
                        }
                      />
                    </label>
                    <label>
                      <span>瑙掕壊瀹氫綅</span>
                      <input
                        value={character.role}
                        onChange={(event) =>
                          updateCharacter(index, 'role', event.target.value)
                        }
                      />
                    </label>
                    <label>
                      <span>鎬ф牸涓庣瀵?</span>
                      <textarea
                        value={character.trait}
                        onChange={(event) =>
                          updateCharacter(index, 'trait', event.target.value)
                        }
                      />
                    </label>
                  </article>
                ))}
              </div>
            </section>
          </aside>
        </div>
      </section>
    </main>
  )
}

export default App
