  async function createNewWorkspace() {
    setWorkspaceState('姝ｅ湪鍒涘缓宸ヤ綔鍖?')
    try {
      const created = await createWorkspace<WorkspaceSummary>({
        name: newWorkspaceName,
        plan: 'creator',
      })
      setActiveWorkspaceId(created.id)
      window.localStorage.setItem(WORKSPACE_STORAGE_KEY, created.id)
      setWorkspaceState('宸插垏鎹㈠埌鏂板伐浣滃尯')
    } catch {
      setWorkspaceState('鍒涘缓澶辫触锛氳妫€鏌?API')
    }
  }

  async function requestLoginCode() {
    setAuthState('姝ｅ湪鍙戦€侀獙璇佺爜')
    try {
      const result = await requestEmailLoginCode({
        email: loginEmail,
        displayName: loginName,
      })
      setAuthState(
        result.debugCode
          ? `Code generated: ${result.debugCode}`
          : `楠岃瘉鐮佸凡鍙戦€佽嚦 ${result.email}`,
      )
    } catch {
      setAuthState('楠岃瘉鐮佸彂閫佸け璐ワ細璇锋鏌ラ偖绠辨垨閭欢鏈嶅姟')
    }
  }

  async function verifyLoginCode() {
    setAuthState('姝ｅ湪楠岃瘉楠岃瘉鐮?')
    try {
      const nextSession = await verifyEmailLoginCode<WorkspaceSession>({
        email: loginEmail,
        code: loginCode,
        displayName: loginName,
        workspaceId: activeWorkspaceId,
      })
      setSession(nextSession)
      setActiveWorkspaceId(nextSession.workspace.id)
      window.localStorage.setItem(WORKSPACE_STORAGE_KEY, nextSession.workspace.id)
      setAuthState(`宸茬櫥褰曪細${nextSession.user.email}`)
      setLoginCode('')
      await refreshTeamState(nextSession.workspace.id)
    } catch {
      setAuthState('楠岃瘉鐮侀獙璇佸け璐ワ細璇锋鏌?6 浣嶉獙璇佺爜')
    }
  }

  async function loginToWorkspace() {
    setAuthState('姝ｅ湪鐧诲綍')
    try {
      if (isNetlifyIdentityAuth) {
        await netlifyIdentityLogin(loginEmail, loginPassword)
        const nextSession = await syncIdentitySession(activeWorkspaceId)
        setAuthState(`宸茬櫥褰曪細${nextSession.user.email}`)
        return
      }
      if (isEmailCodeAuth) {
        await verifyLoginCode()
        return
      }
      if (isGenericProviderAuth) {
        setAuthState('璇烽€氳繃姝ｅ紡鐧诲綍鍏ュ彛杩涘叆锛孉PI 灏嗕粠鍙椾俊韬唤澶村悓姝ヤ細璇?')
        return
      }

      const nextSession = await localApiLogin<WorkspaceSession>({
        email: loginEmail,
        displayName: loginName,
        workspaceId: activeWorkspaceId,
      })
      setSession(nextSession)
      setActiveWorkspaceId(nextSession.workspace.id)
      window.localStorage.setItem(WORKSPACE_STORAGE_KEY, nextSession.workspace.id)
      setAuthState(`宸茬櫥褰曪細${nextSession.user.email}`)
      await refreshTeamState(nextSession.workspace.id)
    } catch (error) {
      setAuthState(
        isNetlifyIdentityAuth ? formatIdentityError(error) : '鐧诲綍澶辫触锛氳妫€鏌ラ偖绠辨垨 API',
      )
    }
  }

  async function signupToWorkspace() {
    if (isEmailCodeAuth) {
      await requestLoginCode()
      return
    }
    if (isGenericProviderAuth) {
      setAuthState('璇峰湪姝ｅ紡璐﹀彿绯荤粺涓垱寤鸿处鍙凤紝鍐嶅洖鍒板伐浣滃彴鍚屾浼氳瘽')
      return
    }
    if (!isNetlifyIdentityAuth) {
      await loginToWorkspace()
      return
    }

    setAuthState('姝ｅ湪鍒涘缓鐪熷疄璐﹀彿')
    try {
      const identityUser = await netlifyIdentitySignup(loginEmail, loginPassword, {
        full_name: loginName,
      })
      if (identityUser.confirmedAt) {
        const nextSession = await syncIdentitySession(activeWorkspaceId)
        setAuthState(`璐﹀彿宸插垱寤猴細${nextSession.user.email}`)
      } else {
        setAuthState('璐﹀彿宸插垱寤猴紝璇峰厛鍒伴偖绠卞畬鎴愮‘璁?')
      }
    } catch (error) {
      setAuthState(formatIdentityError(error))
    }
  }

  async function logoutFromWorkspace() {
    setAuthState('姝ｅ湪閫€鍑?')
    try {
      if (isNetlifyIdentityAuth) {
        await netlifyIdentityLogout()
        setAuthState('宸查€€鍑虹湡瀹炶处鍙?')
        return
      }
      if (isEmailCodeAuth) {
        const nextSession = await localApiLogout<WorkspaceSession>()
        setSession(nextSession)
        setActiveWorkspaceId(nextSession.workspace.id)
        window.localStorage.setItem(WORKSPACE_STORAGE_KEY, nextSession.workspace.id)
        setAuthState('宸查€€鍑洪偖绠遍獙璇佺爜璐﹀彿')
        return
      }
      if (isGenericProviderAuth) {
        setAuthState('璇峰湪姝ｅ紡璐﹀彿绯荤粺涓€€鍑虹櫥褰?')
        return
      }

      const nextSession = await localApiLogout<WorkspaceSession>()
      setSession(nextSession)
      setActiveWorkspaceId(nextSession.workspace.id)
      window.localStorage.setItem(WORKSPACE_STORAGE_KEY, nextSession.workspace.id)
      setAuthState('宸查€€鍑哄埌榛樿璐﹀彿')
      await refreshTeamState(nextSession.workspace.id)
    } catch {
      setAuthState('閫€鍑哄け璐ワ細璇锋鏌?API')
    }
  }

  function switchWorkspace(workspaceId: string) {
    setActiveWorkspaceId(workspaceId)
    window.localStorage.setItem(WORKSPACE_STORAGE_KEY, workspaceId)
    setWorkspaceState('姝ｅ湪鍒囨崲宸ヤ綔鍖?')
  }

  function switchProject(projectId: string) {
    const nextProject = projectList.find((item) => item.id === projectId)
    if (!nextProject) return
    applyProject(nextProject, `宸插垏鎹㈠埌 ${nextProject.title}`)
    setSaveState('宸插垏鎹綔鍝?')
    setBuildState('灏氭湭鐢熸垚鍙戝竷鍖?')
    setPublishedBuildId('')
    setPaymentOrders([])
    setPendingPaidChoice(null)
  }

  async function createNewProject() {
    const nextProject: StoryProject = {
      ...sampleProject,
      id: `playdrama-project-${Date.now()}`,
      title: '鏂扮殑浜掑姩鐭墽',
      lifecycleStatus: 'active',
      archivedAt: null,
      updatedAt: new Date().toISOString(),
    }
    applyProject(nextProject, '宸插垱寤烘柊浣滃搧鑽夌')
    setProjectList((current) => [nextProject, ...current])
    setSaveState('鏂颁綔鍝佽崏绋垮緟淇濆瓨')
    setProjectListState('鏂颁綔鍝佸凡鍔犲叆鍒楄〃')
    await syncProjectToApi(nextProject)
  }

  async function duplicateProject(projectId: string) {
    const sourceProject = projectList.find((item) => item.id === projectId)
    if (!sourceProject) return

    const nextProject: StoryProject = {
      ...sourceProject,
      id: `playdrama-copy-${Date.now()}`,
      title: `${sourceProject.title} 鍓湰`,
      lifecycleStatus: 'active',
      archivedAt: null,
      updatedAt: new Date().toISOString(),
    }

    applyProject(nextProject, '宸插鍒朵綔鍝?')
    setProjectList((current) => [nextProject, ...current])
    setProjectListState('浣滃搧鍓湰宸插垱寤?')
    await syncProjectToApi(nextProject)
  }

  async function archiveProject(projectId: string) {
    const sourceProject = projectList.find((item) => item.id === projectId)
    if (!sourceProject) return

    const archivedAt = new Date().toISOString()
    try {
      await updateRemoteProject<StoryProject>(projectId, {
        lifecycleStatus: 'archived',
        archivedAt,
      })
      const nextList = projectList.filter((item) => item.id !== projectId)
      setProjectList(nextList)
      setArchivedProjectList((current) => [
        {
          ...sourceProject,
          lifecycleStatus: 'archived',
          archivedAt,
        },
        ...current,
      ])
      setProjectListState('浣滃搧宸插綊妗?')

      if (project.id === projectId) {
        const fallbackProject = nextList[0] || {
          ...sampleProject,
          id: `playdrama-project-${Date.now()}`,
          title: '鏂扮殑浜掑姩鐭墽',
          lifecycleStatus: 'active',
          archivedAt: null,
          updatedAt: new Date().toISOString(),
        }
        applyProject(fallbackProject, '褰撳墠浣滃搧宸插綊妗?')
        setSaveState(nextList[0] ? '宸插垏鎹㈠埌涓嬩竴涓綔鍝?' : '褰撳墠宸ヤ綔鍖烘殏鏃犳椿璺冧綔鍝?')
      }

      await refreshTeamState(activeWorkspaceId)
    } catch {
      setProjectListState('褰掓。澶辫触锛氳妫€鏌?API')
    }
  }

  async function restoreProject(projectId: string) {
    const sourceProject = archivedProjectList.find((item) => item.id === projectId)
    if (!sourceProject) return

    try {
      const restoredProject = normalizeProject(
        await updateRemoteProject<StoryProject>(projectId, {
          lifecycleStatus: 'active',
          archivedAt: null,
        }),
      )
      setArchivedProjectList((current) => current.filter((item) => item.id !== projectId))
      setProjectList((current) => [restoredProject, ...current])
      applyProject(restoredProject, '宸叉仮澶嶅綊妗ｄ綔鍝?')
      setProjectListState('褰掓。浣滃搧宸叉仮澶?')
      setSaveState('宸叉仮澶嶄綔鍝?')
      await refreshTeamState(activeWorkspaceId)
    } catch {
      setProjectListState('鎭㈠澶辫触锛氳妫€鏌?API')
    }
  }

  const player = (
    <section className={`panel preview-panel ${previewOnly ? 'published-player-panel' : ''}`}>
      <div className="panel-header">
        <div>
          <p className="eyebrow">Playable Runtime</p>
          <h2>{previewOnly ? '浜掑姩鐭墽' : '鍙帺棰勮'}</h2>
        </div>
        <span className="runtime-progress-pill">
          {runtimeProgress.current}/{runtimeProgress.total}
        </span>
        <button
          className="icon-button"
          type="button"
          aria-label="Restart preview"
          onClick={() => restartRuntime()}
        >
          <RotateCcw size={17} />
        </button>
      </div>
      <div className="runtime-meta-strip">
        <span>{runtimeNode.kind}</span>
        <span>{runtimeAllowedChoiceCount} 涓彲閫夊垎鏀?</span>
        <span>{runtimeProgress.percent}% 鍓ф儏杩涘害</span>
        <span>{project.publish.monetization === 'Paid Ending' ? checkoutState : '鍏嶈垂浣撻獙'}</span>
      </div>
      <div className="runtime-state">
        {project.variables.map((variable) => (
          <label key={variable.id}>
            <span>{variable.label}</span>
            <input
              value={runtimeState[variable.label] ?? variable.defaultValue}
              onChange={(event) =>
                updateRuntimeValue(variable.label, event.target.value)
              }
            />
          </label>
        ))}
      </div>
      <div className="phone-frame">
        <div className="video-scene">
          <div className="scene-topbar">
            <span>{runtimeNode.id}</span>
            <span>{runtimeNode.kind}</span>
          </div>
          <div className="scene-progress">
            <span style={{ width: `${runtimeProgress.percent}%` }} />
          </div>
          <div className="scene-copy">
            <strong>{runtimeNode.title}</strong>
            <p>{runtimeNode.summary}</p>
          </div>
        </div>
        {runtimeNode.choices.map((item) => {
          const allowed = evaluateCondition(item.condition, runtimeState)
          const requiresPayment = choiceRequiresPayment(item)
          return (
            <button
              className={`choice-button ${allowed && !requiresPayment ? '' : 'locked'}`}
              type="button"
              key={item.id}
              onClick={() => playChoice(item)}
            >
              {item.label}
              <span>
                {requiresPayment
                  ? `浠樿垂瑙ｉ攣 路 ${project.publish.price} 鍏僠`
                  : item.condition
                  ? `${allowed ? '婊¤冻' : '閿佸畾'} 路 ${item.condition}`
                  : `杩涘叆 ${item.targetNodeId}`}
              </span>
            </button>
          )
        })}
        {pendingPaidChoice && (
          <div className="checkout-panel">
            <div>
              <strong>瑙ｉ攣浠樿垂缁撳眬</strong>
              <span>{project.publish.monetization} 路 {project.publish.price} 鍏?</span>
            </div>
            <button className="play-button" type="button" onClick={unlockPaidEnding}>
              <ShieldCheck size={17} />
              娌欑洅鏀粯
            </button>
          </div>
        )}
        {runtimeNode.kind === 'Ending' && (
          <button className="play-button" type="button" onClick={() => restartRuntime()}>
            <Play size={17} fill="currentColor" />
            閲嶆柊寮€濮?          </button>
        )}
      </div>
      <div className="runtime-path">
        <span>宸茶蛋璺緞</span>
        <strong>{runtimePathLabel}</strong>
      </div>
      <p className="runtime-message">{runtimeMessage}</p>
    </section>
  )

  if (previewOnly) {
    return (
      <main className="share-preview-shell">
        <header className="share-preview-header">
          <div>
            <p className="eyebrow">Local Share Preview</p>
            <h1>{project.title}</h1>
            <span>{project.publish.category} 路 {project.publish.monetization}</span>
          </div>
          <div className="share-preview-actions">
            <span>{publishedBuildId ? `build #${publishedBuildId.slice(-6)}` : 'local draft'}</span>
            <button className="ghost-button" type="button" onClick={exitSharePreview}>
              杩斿洖鍒涗綔鍙?            </button>
          </div>
        </header>
        <div className="share-preview-body">{player}</div>
      </main>
    )
  }

  return (
    <main className="app-shell">
      <input
        ref={fileInputRef}
        className="file-input"
        type="file"
        accept="application/json,.json"
        onChange={importProject}
      />

      <aside className="sidebar" aria-label="Workspace">
        <div className="brand">
          <div className="brand-mark">
            <Sparkles size={20} />
          </div>
          <div>
            <strong>PlayDrama</strong>
            <span>AI 浜掑姩鐭墽宸ヤ綔鍙?</span>
          </div>
        </div>

        <nav className="nav-list" aria-label="Main">
          <button className="nav-item active" type="button">
            <Layers3 size={18} />
            椤圭洰鎬昏
          </button>
          <button className="nav-item" type="button">
            <GitBranch size={18} />
            鍓ф儏缂栬緫
          </button>
          <button className="nav-item" type="button">
            <Users size={18} />
            瑙掕壊璧勪骇
          </button>
          <button className="nav-item" type="button">
            <Bot size={18} />
            AI 瀵兼紨
          </button>
          <button className="nav-item" type="button">
            <Share2 size={18} />
            鍙戝竷鍙樼幇
          </button>
        </nav>

        <section className="side-section">
          <div className="section-title">
            <span>褰撳墠妯℃澘</span>
            <button className="icon-button" type="button" aria-label="Add template">
              <Plus size={16} />
            </button>
          </div>
          <div className="template-tile">
            <FileText size={18} />
            <div>
              <strong>{project.template}</strong>
              <span>绾跨储銆佸瘑鐮侀攣銆侀殣钘忕粨灞€</span>
            </div>
          </div>
        </section>

        <section className="side-section">
          <div className="section-title">
            <span>宸ヤ綔鍖烘潈闄?</span>
          </div>
          <div className="auth-panel">
            <input
              value={loginEmail}
              onChange={(event) => setLoginEmail(event.target.value)}
              placeholder="鐧诲綍閭"
            />
            <input
              value={loginName}
              onChange={(event) => setLoginName(event.target.value)}
              placeholder="鏄剧ず鍚嶇О"
            />
            {isNetlifyIdentityAuth && (
              <input
                value={loginPassword}
                onChange={(event) => setLoginPassword(event.target.value)}
                placeholder="鐧诲綍瀵嗙爜"
                type="password"
              />
            )}
            {isEmailCodeAuth && (
              <input
                value={loginCode}
                onChange={(event) => setLoginCode(event.target.value)}
                placeholder="6 浣嶉獙璇佺爜"
                inputMode="numeric"
                maxLength={6}
              />
            )}
            <div className="auth-actions">
              <button className="ghost-button compact" type="button" onClick={loginToWorkspace}>
                {isGenericProviderAuth ? '鍚屾' : isEmailCodeAuth ? '验证登录' : '鐧诲綍'}
              </button>
              {(isNetlifyIdentityAuth || isGenericProviderAuth || isEmailCodeAuth) && (
                <button className="ghost-button compact" type="button" onClick={signupToWorkspace}>
                  {isEmailCodeAuth ? '发送验证码' : '娉ㄥ唽'}
                </button>
              )}
              <button className="ghost-button compact" type="button" onClick={logoutFromWorkspace}>
                閫€鍑?              </button>
            </div>
            <div className="auth-provider-badge">
              <span>璁よ瘉妯″紡</span>
              <strong>{authProvider?.provider || 'local-demo'}</strong>
              <small>
                {authProvider?.productionReady ? '鐢熶骇鍙敤' : '鏈湴婕旂ず'} 路{' '}
                {authProvider?.requestScoped ? '璇锋眰绾т細璇?' : '澶栭儴浼氳瘽'}
              </small>
            </div>
            <span className="workspace-state">{authState}</span>
          </div>
          <div className="storage-status-card">
            <strong>
              鏁版嵁搴?路 {storageHealth?.driver || 'json'} 路{' '}
              {storageHealth?.productionReady ? 'Cloud ready' : 'Local / pending'}
            </strong>
            {(storageHealth?.missing || []).slice(0, 3).map((item) => (
              <div className="storage-status-row" key={item.id}>
                <span>{item.label}</span>
                <em>{item.action}</em>
              </div>
            ))}
          </div>
          <div className="commercial-readiness-card">
            <strong>
              鍟嗙敤浣撴 路{' '}
              {commercialReadiness?.status === 'pass' ? 'Ready' : 'Pending'}
            </strong>
            <span>
              {commercialReadiness
                ? `${commercialReadiness.passed}/${commercialReadiness.total} 椤归€氳繃`
                : '绛夊緟 API 鍚屾'}
            </span>
            {(commercialReadiness?.missing || []).slice(0, 4).map((item) => (
              <div className="commercial-readiness-row" key={item.id}>
                <span>
                  {item.area} 路 {item.label}
                </span>
                <em>{item.missingFields.slice(0, 3).join(', ') || item.action}</em>
              </div>
            ))}
          </div>
          <label className="workspace-switcher">
            <span>褰撳墠宸ヤ綔鍖?</span>
            <select
              value={activeWorkspaceId}
              onChange={(event) => switchWorkspace(event.target.value)}
            >
              {workspaceList.length === 0 && (
                <option value={activeWorkspaceId}>Creator Studio</option>
              )}
              {workspaceList.map((item) => (
                <option key={item.id} value={item.id}>
                  {item.name}
                </option>
              ))}
            </select>
          </label>
          <div className="workspace-card">
            <span className="avatar-badge">
              {session?.user.avatarInitials || 'AI'}
            </span>
            <div>
              <strong>{session?.workspace.name || 'Creator Studio'}</strong>
              <span>
                {session?.user.displayName || 'Creator'} 路{' '}
                {session?.membership.role || 'owner'}
              </span>
            </div>
          </div>
          <div className="permission-list">
            {(session?.membership.permissions || ['project:read']).map((item) => (
              <span key={item}>{item}</span>
            ))}
          </div>
          <div className="workspace-create">
            <input
              value={newWorkspaceName}
              onChange={(event) => setNewWorkspaceName(event.target.value)}
            />
            <button className="ghost-button compact" type="button" onClick={createNewWorkspace}>
              <Plus size={16} />
              鏂板缓
            </button>
          </div>
          <span className="workspace-state">{workspaceState}</span>
        </section>
      </aside>

      <section className="workspace">
        <header className="topbar">
          <div>
            <p className="eyebrow">MVP Prototype</p>
            <input
              className="project-title-input"
              value={project.title}
              onChange={(event) =>
                updateProject((current) => ({
                  ...current,
                  title: event.target.value,
                }))
              }
            />
          </div>
          <div className="topbar-actions">
            <label className="search">
              <Search size={17} />
              <input
                placeholder="Search nodes, roles, variables"
                value={searchQuery}
                onChange={(event) => setSearchQuery(event.target.value)}
              />
            </label>
            <span className="save-state">{saveState}</span>
            <button
              className="ghost-button"
              type="button"
              onClick={() => fileInputRef.current?.click()}
            >
              <Upload size={17} />
              瀵煎叆
            </button>
            <button className="ghost-button" type="button" onClick={exportProject}>
              <Download size={17} />
              瀵煎嚭
            </button>
            <button className="ghost-button" type="button" onClick={resetSampleProject}>
              <RotateCcw size={17} />
              閲嶇疆
            </button>
            <button className="ghost-button" type="button" onClick={openSharePreview}>
              <Share2 size={17} />
              棰勮閾炬帴
            </button>
            <button className="primary-button" type="button" onClick={saveProject}>
              <Save size={17} />
              淇濆瓨
            </button>
          </div>
        </header>

        <section className="command-deck" aria-label="Studio command deck">
        <section className="launch-hero" aria-label="Commercial launch status">
          <div className="launch-hero-copy">
            <div className="hero-kicker">
              <Rocket size={16} />
              <span>Commercial Launch Workspace</span>
            </div>
            <h1>浠庝簰鍔ㄧ煭鍓у垱浣滐紝鍒颁笂绾块獙鏀跺拰鍥㈤槦杩愯惀</h1>
