              </button>
              <button className="primary-button compact" type="button" onClick={createNewProject}>
                <Plus size={16} />
                鏂板缓浣滃搧
              </button>
            </div>
          </div>
          <div className="project-switch-list">
            {projectList.length === 0 && (
              <article className="project-switch-empty">
                <strong>褰撳墠宸ヤ綔鍖鸿繕娌℃湁淇濆瓨浣滃搧</strong>
                <span>鐐瑰嚮淇濆瓨鎴栨柊寤轰綔鍝佸悗锛屼細鍑虹幇鍦ㄨ繖閲屻€?</span>
              </article>
            )}
            {projectList.map((item) => (
              <article
                className={`project-switch-item ${item.id === project.id ? 'active' : ''}`}
                key={item.id}
              >
                <button type="button" onClick={() => switchProject(item.id)}>
                  <strong>{item.title}</strong>
                  <span>{item.publish.category} 路 {item.publish.status}</span>
                  <em>{item.nodes.length} 鑺傜偣</em>
                </button>
                <div className="project-card-actions">
                  <button type="button" onClick={() => duplicateProject(item.id)}>
                    澶嶅埗
                  </button>
                  <button type="button" onClick={() => archiveProject(item.id)}>
                    褰掓。
                  </button>
                </div>
              </article>
            ))}
          </div>
          {showArchivedProjects && (
            <div className="archived-projects">
              <div className="section-title light">
                <span>褰掓。浣滃搧</span>
              </div>
              {archivedProjectList.length === 0 && (
                <article className="project-switch-empty">
                  <strong>鏆傛棤褰掓。浣滃搧</strong>
                  <span>褰掓。鍚庣殑浣滃搧浼氫繚鐣欏湪杩欓噷锛屽彲闅忔椂鎭㈠銆?</span>
                </article>
              )}
              {archivedProjectList.map((item) => (
                <article className="project-switch-item archived" key={item.id}>
                  <button type="button" onClick={() => restoreProject(item.id)}>
                    <strong>{item.title}</strong>
                    <span>{item.publish.category} 路 宸插綊妗?</span>
                    <em>{item.nodes.length} 鑺傜偣</em>
                  </button>
                  <div className="project-card-actions">
                    <button type="button" onClick={() => restoreProject(item.id)}>
                      鎭㈠
                    </button>
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>

        <div className="content-grid">
