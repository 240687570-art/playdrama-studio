APP_BASE_URL=https://your-domain.example
PLAYDRAMA_STORAGE_DRIVER=postgres
PLAYDRAMA_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/playdrama
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/playdrama

AUTH_PROVIDER=sms-code
AUTH_PROVIDER_ADAPTER_READY=true
AUTH_SESSION_SECRET=replace-with-a-long-random-secret
AUTH_SMS_CODE_READY=true
AUTH_SMS_CODE_DEV_REVEAL=false

SMS_PROVIDER=tencent-sms
TENCENTCLOUD_SECRET_ID=replace-me
TENCENTCLOUD_SECRET_KEY=replace-me
TENCENT_SMS_SDK_APP_ID=replace-me
TENCENT_SMS_SIGN_NAME=replace-me
TENCENT_SMS_TEMPLATE_ID=replace-me
TENCENT_SMS_TEMPLATE_PARAMS=code
TENCENT_SMS_DRY_RUN=false
TENCENT_SMS_REGION=ap-guangzhou

EMAIL_PROVIDER=aliyun-directmail
PLAYDRAMA_LEAD_NOTIFY_EMAIL=ops@example.com
ALIYUN_ACCESS_KEY_ID=replace-me
ALIYUN_ACCESS_KEY_SECRET=replace-me
ALIYUN_DM_ACCOUNT_NAME=noreply@mail.your-domain.example
ALIYUN_DM_DRY_RUN=false

AI_PROVIDER=qwen
AI_MODEL_NAME=qwen-plus
QWEN_API_KEY=replace-me
AI_REQUEST_TIMEOUT_MS=120000
AI_PROVIDER_ADAPTER_READY=true
AI_COST_TRACKING_READY=true

# Short drama video generation provider.
# DashScope / Wanxiang can reuse QWEN_API_KEY; set DASHSCOPE_API_KEY only if it differs.
VIDEO_PROVIDER=dashscope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
DASHSCOPE_VIDEO_MODEL=wan2.7-t2v-2026-04-25
VIDEO_REQUEST_TIMEOUT_MS=60000

# MiniMax / Hailuo fallback.
# MINIMAX_API_KEY=replace-me
# MINIMAX_BASE_URL=https://api.minimax.io
# MINIMAX_VIDEO_MODEL=video-01

CONTENT_SAFETY_PROVIDER=local-rules
CONTENT_SAFETY_POLICY_READY=true
CONTENT_SAFETY_POLICY_VERSION=local-rules-v1
PAYMENT_PROVIDER=sandbox
PAYMENT_SANDBOX_READY=true
PAYMENT_SANDBOX_VERIFIED=true
ALIPAY_NOTIFY_URL=https://playdrama.tokenaicloud.com/api/payment/callbacks/alipay
WECHAT_PAY_NOTIFY_URL=https://playdrama.tokenaicloud.com/api/payment/callbacks/wechat

# Mini-program launch placeholders. Fill after Douyin/WeChat app approval.
MINI_PROGRAM_WEBVIEW_DOMAIN_READY=false
DOUYIN_CLIENT_KEY=replace-me
DOUYIN_CLIENT_SECRET=replace-me
DOUYIN_ACCESS_TOKEN=replace-me
DOUYIN_OPEN_ID=replace-me
DOUYIN_MINI_APP_ID=replace-me
DOUYIN_MINI_APP_SECRET=replace-me
DOUYIN_MINI_PAY_READY=false
WECHAT_MINI_APP_ID=replace-me
WECHAT_MINI_APP_SECRET=replace-me
WECHAT_MINI_ORIGINAL_ID=replace-me
WECHAT_MINI_PAY_READY=false
